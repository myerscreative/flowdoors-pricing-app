rules_version = '2';

// ============================================================================
// FlowDoors Firestore Security Rules — Phase A (auth required)
// ----------------------------------------------------------------------------
// Every request must come from a signed-in user. API routes that use the
// Firebase Admin SDK bypass these rules automatically, so server-side
// operations are unaffected.
//
// Next step (Phase B): tighten per-collection by role. See comments inline.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function hasRole(roleList) {
      return isSignedIn()
        && request.auth.token.role is string
        && request.auth.token.role in roleList;
    }

    // Salespeople (directory). Needed by useCurrentUserRole fallback path.
    match /salespeople/{id} {
      allow read:  if isSignedIn();
      allow write: if hasRole(['admin', 'manager']);
    }

    // Orders and their task subcollection.
    // Customers can read only their own orders; staff can read/write all.
    function isCustomerForOrder(orderData) {
      return isSignedIn()
        && request.auth.token.role == 'customer'
        && (
          orderData.customerUid == request.auth.uid
          || orderData.email == request.auth.token.email
        );
    }

    match /orders/{orderId} {
      allow read: if hasRole(['admin', 'manager', 'salesperson', 'marketing'])
        || isCustomerForOrder(resource.data);
      allow write: if hasRole(['admin', 'manager', 'salesperson']);

      match /tasks/{taskId} {
        allow read, write: if hasRole(['admin', 'manager', 'salesperson']);
      }

      match /{sub=**} {
        allow read, write: if hasRole(['admin', 'manager', 'salesperson']);
      }
    }

    // Global task templates (the "Manage Templates" dialog). Admins edit.
    match /taskTemplates/{id} {
      allow read:  if isSignedIn();
      allow write: if hasRole(['admin', 'manager']);
    }

    // Global follow-up notes.
    match /notes/{id} {
      allow read, write: if isSignedIn();
    }

    // Other collections this app uses today (quotes, leads, users, marketing,
    // kanban state, email events, etc.). Keep authenticated-only for now.
    // Phase B: narrow each to the roles that actually need it.
    match /quotes/{id}            { allow read, write: if isSignedIn(); }
    match /leads/{id}             { allow read, write: if isSignedIn(); }
    match /referrals/{id}         { allow read, write: if isSignedIn(); }
    match /emailEvents/{id}       { allow read, write: if isSignedIn(); }
    match /marketingCohorts/{id}  { allow read, write: if isSignedIn(); }
    match /notificationSettings/{id} { allow read, write: if isSignedIn(); }
    match /kanban/{id}            { allow read, write: if isSignedIn(); }

    // Default: deny anything not explicitly matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
